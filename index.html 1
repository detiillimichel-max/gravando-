 document.querySelectorAll('.sheet-item').forEach(b=>b.onclick=async()=>{const act=b.dataset.action;const rec=currentSheetRec;closeSheet();if(!rec)return;if(act==='rename'){const nn=prompt('Renomear gravação:',rec.name);if(nn&&nn.trim()){rec.name=nn.trim();await dbUpdate(rec);renderList($('searchInput').value)}}else if(act==='delete'){if(confirm('Excluir esta gravação permanentemente?')){await dbDelete(rec.id);URL.revokeObjectURL(rec.url);recordings=recordings.filter(r=>r.id!==rec.id);if(currentId===rec.id)stopCurrentAudio();renderList($('searchInput').value)}}else if(act==='share'){const a=document.createElement('a');a.href=rec.url;a.download=`${rec.name}.webm`;a.click()}else if(act==='details'){alert(`Nome: ${rec.name}\nData: ${formatFullDate(rec.date)}\nDuração: ${formatDuration(rec.duration)}\nTamanho: ${formatSize(rec.size)}`)}});

